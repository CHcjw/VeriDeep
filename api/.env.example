# ===== LLM（智谱 GLM / BigModel，OpenAI 兼容）=====
# 必填：从智谱开放平台 https://open.bigmodel.cn 控制台获取的 API Key
ZHIPU_API_KEY=your_zhipu_api_key_here

# 模型名：默认 glm-5-turbo（质量最高，带思考模式，长输出能力强）
# 备选：glm-4-air（Agent 专用，速度快并发高，适合调试）、glm-4.6（推理模型）
ZHIPU_MODEL=glm-5-turbo
# BigModel OpenAI 兼容网关地址
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ===== 搜索 API（采集 Agent 用）=====
# 博查 Bocha Web Search（必填，从 https://open.bocha.cn 获取，形如 sk-xxxxxx）
BOCHA_API_KEY=sk-xxxxxx
# 博查接口网关（一般无需改）
BOCHA_BASE_URL=https://api.bocha.cn/v1

# ===== 自媒体平台采集器 cookie/token（可选）=====
DOUYIN_COOKIE=
BILIBILI_COOKIE=
XHS_COOKIE=

# ===== 服务配置 =====
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:3400
ENABLE_DEMO_FALLBACK=true
